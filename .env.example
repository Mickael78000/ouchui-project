# WalletConnect project ID — get one at https://cloud.walletconnect.com
NEXT_PUBLIC_WALLET_CONNECT_PROJECT_ID=your_walletconnect_project_id

# Sepolia RPC URL (e.g. Alchemy, Infura, or public endpoint)
NEXT_PUBLIC_SEPOLIA_RPC_URL=https://eth-sepolia.g.alchemy.com/v2/your_alchemy_api_key

# Local Hardhat node RPC (default)
NEXT_PUBLIC_HARDHAT_RPC_URL=http://127.0.0.1:8545